{
  "metadata": {"key": "orderForm", "name": "Order Form", "modelType": "form"},
  "rows": [
    [
      {
        "id": "customer",
        "type": "select",
        "label": "Customer",
        "extraSettings": {"queryUrl": "/api/customers"}
      }
    ],
    [
      {"id": "amount", "type": "number", "label": "Amount", "isRequired": true}
    ],
    [
      {"id": "totalDisplay", "type": "text", "label": "Total", "value": "{{amount}}"}
    ],
    [
      {
        "id": "lookupCustomer",
        "type": "button",
        "label": "Lookup customer",
        "extraSettings": {"serviceModel": {"serviceModelKey": "customerService", "operationKey": "findAll"}}
      }
    ],
    [
      {
        "id": "customerRecord",
        "type": "select",
        "label": "Customer record",
        "extraSettings": {"dataObjectDefinitionKey": "customerDO", "dataObjectOperationKey": "findAll"}
      }
    ]
  ],
  "outcomes": [
    {"value": "approve", "label": "Approve"}
  ]
}
