<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" id="orderDecisionDef" name="Order decision">
  <decision id="orderDecision" name="Order decision">
    <decisionTable id="dt1" hitPolicy="FIRST">
      <input id="in1" label="total">
        <inputExpression id="ie1" typeRef="number"><text>total</text></inputExpression>
      </input>
      <output id="out1" label="approved" name="approved" typeRef="boolean"/>
      <rule id="r1">
        <inputEntry id="uie1"><text>&gt; 100</text></inputEntry>
        <outputEntry id="uoe1"><text>true</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
