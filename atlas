#!/usr/bin/env bash
#
# Flowable Atlas — one-command launcher (JVM edition).
#
#   ./atlas <project-dir-or-zip> [output-dir]
#
# Analyzes any Flowable project (models + Java) and writes 5 artifacts into the
# output dir (default: ./atlas-output/<project>/), then opens the HTML explorer.
#
#   <project>.explorer.html   interactive, human-friendly explorer (opens automatically)
#   <project>.summary.md      compact LLM-first overview (~few KB)
#   <project>.overview.md     full human/LLM Markdown report
#   <project>.graph.json      full traversable model+code graph
#   <project>.CLAUDE.md       AI-agent context (Flowable primer + this project's facts)
#
# This runs the standalone Kotlin CLI fat-jar (the successor to flowable_atlas.py).
# Pass any extra flags after the paths to override (e.g. --no-open, see below).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JAVA="${JAVA:-java}"

if [[ $# -lt 1 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<EOF
Flowable Atlas — map any Flowable project into an interactive explorer + LLM overview.

Usage:
  ./atlas <project-dir-or-zip> [output-dir] [extra flags]

Examples:
  ./atlas ~/projects/my-flowable-app
  ./atlas ~/projects/my-flowable-app ./reports
  ./atlas /path/to/app.zip --no-open

Outputs (in the output dir, default ./atlas-output/<project>/):
  <project>.explorer.html   interactive explorer (opens automatically)
  <project>.summary.md      compact LLM overview
  <project>.overview.md     full Markdown report
  <project>.graph.json      traversable graph (for agents/LLMs)
  <project>.CLAUDE.md       AI-agent context (Flowable primer + this project's facts)

Advanced (run the fat-jar directly for single artifacts):
  $JAVA -jar <cli-all.jar> <project> --summary --stdout
  $JAVA -jar <cli-all.jar> <project> --json -o graph.json
  $JAVA -jar <cli-all.jar> <project> --claude        # writes CLAUDE.md
EOF
  exit 0
fi

if ! command -v "$JAVA" >/dev/null 2>&1; then
  echo "error: java not found. Install a JDK 21+ (or set JAVA=/path/to/java)." >&2
  exit 1
fi

# Locate the self-contained Shadow fat-jar. Search order lets an offline/foreign machine run Atlas
# with just Java 21 + a copied jar (no Gradle/Maven/network): an explicit $ATLAS_JAR, a jar shipped
# next to this script or under ./lib/, then the local Gradle build output.
find_jar() {
  if [[ -n "${ATLAS_JAR:-}" && -e "${ATLAS_JAR:-}" ]]; then echo "$ATLAS_JAR"; return; fi
  ls -t "$SCRIPT_DIR"/*-all.jar "$SCRIPT_DIR"/lib/*-all.jar "$SCRIPT_DIR"/cli/build/libs/*-all.jar 2>/dev/null | head -n 1
}
JAR="$(find_jar || true)"
if [[ -z "${JAR:-}" ]]; then
  # No jar found: build it (convenient on a dev machine with network). Set ATLAS_NO_BUILD=1 to skip
  # the build on a locked-down/offline machine, where `./gradlew` would otherwise hang trying to
  # reach Maven Central / the Gradle Plugin Portal (there, `git pull` fetches lib/cli-<version>-all.jar).
  if [[ "${ATLAS_NO_BUILD:-0}" == "1" ]]; then
    echo "error: no Atlas CLI jar found and ATLAS_NO_BUILD=1 is set." >&2
    echo "  Fetch the committed jar with 'git pull' (lib/cli-<version>-all.jar), or set ATLAS_JAR=/path/to/cli-all.jar." >&2
    exit 1
  fi
  echo "▶ No prebuilt Atlas jar found — building it with Gradle (first run)." >&2
  echo "  This needs network access (Maven Central + Gradle Plugin Portal). If it hangs on an" >&2
  echo "  offline/locked-down machine: Ctrl-C, then 'git pull' (ships lib/cli-<version>-all.jar)" >&2
  echo "  or set ATLAS_JAR=/path/to/cli-all.jar (and ATLAS_NO_BUILD=1 to skip this build next time)." >&2
  (cd "$SCRIPT_DIR" && ./gradlew --console=plain -q :cli:shadowJar)
  JAR="$(find_jar || true)"
fi
if [[ -z "${JAR:-}" ]]; then
  echo "error: could not locate or build the CLI fat-jar." >&2
  exit 1
fi

TARGET="$1"; shift || true
if [[ ! -e "$TARGET" ]]; then
  echo "error: not found: $TARGET" >&2
  exit 1
fi

# Optional 2nd positional arg = output dir (anything starting with '-' is a flag).
OUTDIR=""
if [[ $# -ge 1 && "${1:0:1}" != "-" ]]; then
  OUTDIR="$1"; shift
fi

NAME="$(basename "${TARGET%/}")"; NAME="${NAME%.*}"
OUTDIR="${OUTDIR:-$SCRIPT_DIR/atlas-output/$NAME}"

OPEN_FLAG="--open"
EXTRA=()
for a in "$@"; do
  if [[ "$a" == "--no-open" ]]; then OPEN_FLAG=""; else EXTRA+=("$a"); fi
done

echo "▶ Flowable Atlas: analyzing '$TARGET' → '$OUTDIR'"
"$JAVA" -jar "$JAR" "$TARGET" --all -o "$OUTDIR" $OPEN_FLAG "${EXTRA[@]+"${EXTRA[@]}"}"
echo "✓ Done. Open: $OUTDIR/$NAME.explorer.html"
